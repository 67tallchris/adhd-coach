{
  "name": "ADHD Coach - Focus & Productivity",
  "short_name": "ADHD Coach",
  "description": "Your personal ADHD focus companion - track focus, build habits, and boost productivity",
  "start_url": "/app",
  "display": "standalone",
  "background_color": "#111827",
  "theme_color": "#4f5bff",
  "orientation": "portrait-primary",
  "icons": [
    {
      "src": "/brain.svg",
      "sizes": "any",
      "type": "image/svg+xml",
      "purpose": "any maskable"
    },
    {
      "src": "/icon-192.png",
      "sizes": "192x192",
      "type": "image/png",
      "purpose": "any maskable"
    },
    {
      "src": "/icon-512.png",
      "sizes": "512x512",
      "type": "image/png",
      "purpose": "any maskable"
    }
  ],
  "categories": ["productivity", "health", "lifestyle"],
  "screenshots": [],
  "shortcuts": [
    {
      "name": "Log Focus",
      "short_name": "Focus",
      "description": "Quickly log your current focus level",
      "url": "/app/focus",
      "icons": [{ "src": "/brain.svg", "sizes": "any" }]
    },
    {
      "name": "Start Pomodoro",
      "short_name": "Pomodoro",
      "description": "Start a focus session",
      "url": "/app/pomodoro",
      "icons": [{ "src": "/brain.svg", "sizes": "any" }]
    }
  ],
  "share_target": {
    "action": "/app/brain-dump",
    "method": "GET",
    "params": {
      "title": "title",
      "text": "notes"
    }
  }
}
